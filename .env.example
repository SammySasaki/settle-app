# Copy this file to .env and fill in the values

# Railway PostgreSQL connection string
# Found in: Railway project → your Postgres service → Variables → DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Anthropic API key for AI suggestions
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Secret token for the cleanup cron job — any random string
# Generate one with: openssl rand -hex 32
CRON_SECRET=

# Google Places API key for solo mode (optional — degrades gracefully without it)
# Set up: console.cloud.google.com → enable "Places API (New)" → Credentials → Create API key
# Restrict the key to "Places API (New)" only
GOOGLE_PLACES_API_KEY=
